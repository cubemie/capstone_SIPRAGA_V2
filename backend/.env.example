# ============================================================
# Template .env untuk Docker Compose
# Salin ke backend/.env:  cp .env.example .env
# DB_HOST=db dan REDIS_HOST=redis adalah nama service di docker-compose.yml
# JANGAN ganti ke localhost kecuali menjalankan backend di luar Docker.
# ============================================================

# Server Configuration
PORT=3000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration (service Docker: db)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=capstone

# JWT Configuration
JWT_SECRET=ganti-dengan-secret-yang-kuat-dan-panjang-min-32-karakter

# Email / SMTP Configuration (opsional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# WhatsApp via Fonnte (opsional)
FONNTE_TOKEN=your-fonnte-token-here

# Queue / Redis (service Docker: redis)
REDIS_HOST=redis
REDIS_PORT=6379

# Storage: Supabase (opsional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Storage: Cloudinary (opsional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
