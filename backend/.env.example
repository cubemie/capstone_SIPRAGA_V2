# Server Configuration
PORT=3000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=capstone

# JWT Configuration
JWT_SECRET=ganti-dengan-secret-yang-kuat-dan-panjang-min-32-karakter

# Email / SMTP Configuration (opsional — jika kosong pakai Ethereal fake SMTP)
# Contoh: Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# WhatsApp via Fonnte (opsional — jika tidak diset, WA notification dilewati)
FONNTE_TOKEN=your-fonnte-token-here
