### A.5 Riwayat Surat RT/RW — Terhubung ke V2

#### `backend/src/modules/letters/letters.routes.js` — Tambah endpoint history

```js
// Tambah di letters.routes.js
// GET /api/v2/letters/history → history semua surat yang sudah diproses RT/RW
router.get('/history', authRtRwMiddleware, LettersController.getHistory);
```

#### `backend/src/modules/letters/letters.controller.js` — Tambah getHistory

```js
// Tambah method getHistory di LettersController

static async getHistory(req, res) {
  try {
    const { role } = req.user;
    const tenantId = req.tenantId;

    // History = semua surat yang SUDAH punya approval dari role ini
    // (status: completed, rejected, revision_requested)
    let whereClause;
    let params;

    if (role === 'rt') {
      whereClause = `l.status IN ('completed', 'rejected', 'approved_rt', 'revision_requested')
                     AND l.tenant_id = ?`;
      params = [tenantId];
    } else {
      // rw: surat yang sudah melewati tahap RW
      whereClause = `l.status IN ('completed', 'rejected') AND la.step >= 2`;
      params = [];
    }

    const [rows] = await pool.query(
      `SELECT DISTINCT
         l.uuid, l.status, l.created_at, l.completed_at, l.subject,
         lt.name AS letter_type_name,
         w.nama AS resident_name, w.NIK AS resident_nik,
         la.action AS last_action, la.acted_at AS last_acted_at
       FROM letters l
       JOIN letter_types lt ON l.letter_type_id = lt.id
       JOIN warga w ON l.resident_id = w.id_warga
       LEFT JOIN letter_approvals la ON la.letter_id = l.id
       WHERE ${whereClause}
       ORDER BY COALESCE(la.acted_at, l.created_at) DESC
       LIMIT 100`,
      params
    );

    res.json({ success: true, data: rows });
  } catch (err) {
    console.error('Error getHistory:', err);
    res.status(500).json({ success: false, message: 'Gagal mengambil riwayat' });
  }
}
```

#### `frontend/src/pages/rtrw/RiwayatSurat.jsx` — Ganti isi

```jsx
// frontend/src/pages/rtrw/RiwayatSurat.jsx
// Versi lengkap yang nyambung ke API V2

import React, { useState } from 'react';
import { useQuery } from '@tanstack/react-query';
import { Link } from 'react-router-dom';
import { api } from '../../utils/api';
import { getStatusV2 } from '../../constants/suratStatus';
import { Search, FileText, ChevronRight } from 'lucide-react';

const formatDate = (str) => {
  if (!str) return '-';
  return new Date(str).toLocaleDateString('id-ID', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
};

export default function RiwayatSurat() {
  const [search, setSearch] = useState('');
  const [filterStatus, setFilterStatus] = useState('all');

  const { data: letters = [], isLoading } = useQuery({
    queryKey: ['rtrw-history'],
    queryFn: async () => {
      const { data, error } = await api.get('/v2/letters/history');
      if (error) throw new Error(error);
      return data?.data || [];
    },
  });

  const filtered = letters.filter((l) => {
    const matchStatus =
      filterStatus === 'all'       ? true :
      filterStatus === 'completed' ? l.status === 'completed' :
      filterStatus === 'rejected'  ? l.status === 'rejected' :
      true;

    const matchSearch = !search || [l.resident_name, l.letter_type_name]
      .some(s => s?.toLowerCase().includes(search.toLowerCase()));

    return matchStatus && matchSearch;
  });

  return (
    <div className="p-4 md:p-6 max-w-4xl mx-auto">
      <div className="mb-6">
        <h1 className="text-xl font-bold text-ink">Riwayat Surat</h1>
        <p className="text-sm text-ink-secondary mt-0.5">
          Semua surat yang sudah kamu proses
        </p>
      </div>

      {/* Filter toolbar */}
      <div className="flex gap-2 mb-4 flex-col sm:flex-row">
        <div className="relative flex-1">
          <Search className="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" />
          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="Cari nama warga / jenis surat..."
            className="w-full pl-9 pr-4 py-2 text-sm border border-surface-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
        <select
          value={filterStatus}
          onChange={e => setFilterStatus(e.target.value)}
          className="px-3 py-2 text-sm border border-surface-border rounded-lg text-ink-secondary focus:outline-none"
        >
          <option value="all">Semua Status</option>
          <option value="completed">Selesai</option>
          <option value="rejected">Ditolak</option>
        </select>
      </div>

      <div className="bg-white border border-surface-border rounded-xl overflow-hidden">
        {isLoading && (
          <div className="p-6 space-y-3">
            {[1,2,3].map(i => <div key={i} className="h-16 bg-surface-muted rounded-lg animate-pulse" />)}
          </div>
        )}

        {!isLoading && filtered.length === 0 && (
          <div className="py-16 text-center text-ink-muted">
            <FileText className="w-10 h-10 mx-auto mb-3 text-slate-200" />
            <p className="text-sm font-medium text-ink-secondary">Belum ada riwayat surat</p>
          </div>
        )}

        {filtered.map((letter) => {
          const statusInfo = getStatusV2(letter.status);
          return (
            <Link
              key={letter.uuid}
              to={`/rtrw/surat/${letter.uuid}`}
              className="flex items-center gap-4 px-5 py-4 border-b border-surface-border hover:bg-surface-muted/50 transition group last:border-0"
            >
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap">
                  <p className="text-sm font-semibold text-ink">{letter.resident_name}</p>
                  <span className={`text-xs px-2 py-0.5 rounded-full border font-medium ${statusInfo.color}`}>
                    {statusInfo.label}
                  </span>
                </div>
                <p className="text-xs text-ink-secondary mt-0.5">{letter.letter_type_name}</p>
                <p className="text-xs text-ink-muted mt-0.5">
                  Diajukan {formatDate(letter.created_at)}
                  {letter.completed_at && ` · Selesai ${formatDate(letter.completed_at)}`}
                </p>
              </div>
              <ChevronRight className="w-4 h-4 text-ink-muted group-hover:text-ink transition flex-shrink-0" />
            </Link>
          );
        })}
      </div>
    </div>
  );
}
```

