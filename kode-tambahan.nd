const [sortBy, setSortBy]   = useState('newest'); // 'newest' | 'oldest' | 'status'

// Filter logic (ganti yang ada):
const filtered = letters
  .filter((l) => {
    const matchTab =
      activeTab === 'all'       ? true :
      activeTab === 'process'   ? PROCESS_STATUSES.includes(l.status) :
      activeTab === 'completed' ? l.status === 'completed' :
      activeTab === 'rejected'  ? ['rejected', 'cancelled'].includes(l.status) :
      true;

    const matchSearch = !search || [
      l.letter_type_name, l.subject, l.purpose,
    ].some(s => s?.toLowerCase().includes(search.toLowerCase()));

    return matchTab && matchSearch;
  })
  .sort((a, b) => {
    if (sortBy === 'oldest') return new Date(a.created_at) - new Date(b.created_at);
    if (sortBy === 'status') return a.status.localeCompare(b.status);
    return new Date(b.created_at) - new Date(a.created_at); // newest default
  });

