## BAGIAN E — MIDDLEWARE: LOG OTOMATIS

### `backend/src/middlewares/auditLogger.js` — BARU

Middleware ini otomatis log semua action penting ke tabel `system_logs`.

```js
// backend/src/middlewares/auditLogger.js

const pool = require('../config/db');

/**
 * Buat middleware audit logger yang otomatis log request tertentu.
 * @param {string} action - nama action (e.g. 'APPROVE_LETTER')
 * @param {string} targetType - tipe target (e.g. 'letter')
 * @param {Function} getTargetId - fungsi (req) => string id
 */
const createAuditLog = (action, targetType, getTargetId = () => null) => {
  return async (req, res, next) => {
    // Simpan original json method
    const originalJson = res.json.bind(res);

    res.json = async (body) => {
      // Hanya log jika sukses (status 2xx)
      if (res.statusCode >= 200 && res.statusCode < 300) {
        try {
          const user = req.user || req.rtRwUser;
          if (user) {
            const actorId   = user.id_warga || user.id;
            const actorRole = user.role;
            const actorName = user.nama || user.username || '';
            const targetId  = getTargetId(req);

            await pool.query(
              `INSERT INTO system_logs
                 (actor_id, actor_role, actor_name, action, target_type, target_id, ip_address)
               VALUES (?, ?, ?, ?, ?, ?, ?)`,
              [actorId, actorRole, actorName, action, targetType, targetId,
               req.ip || req.connection?.remoteAddress]
            );
          }
        } catch (err) {
          // Jangan gagalkan request karena log error
          console.error('[AuditLog]', err.message);
        }
      }
      return originalJson(body);
    };

    next();
  };
};

module.exports = { createAuditLog };
```

**Cara pakai di routes:**
```js
// Contoh pemakaian di letters.routes.js
const { createAuditLog } = require('../../middlewares/auditLogger');

router.post(
  '/:uuid/approve',
  authRtRwMiddleware,
  createAuditLog('APPROVE_LETTER', 'letter', (req) => req.params.uuid),
  LettersController.approveLetter
);

router.post(
  '/:uuid/reject',
  authRtRwMiddleware,
  createAuditLog('REJECT_LETTER', 'letter', (req) => req.params.uuid),
  LettersController.rejectLetter
);
```

